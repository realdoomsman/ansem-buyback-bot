# ============================================================
# $ANSEM Buy-Back & Airdrop Bot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control!
# ============================================================

# --- Solana RPC Configuration ---
# A premium RPC endpoint is REQUIRED for getProgramAccounts (holder snapshots).
# Recommended providers: Helius, QuickNode, Triton
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WSS_URL=wss://api.mainnet-beta.solana.com

# --- Wallet Configuration ---
# The private key (base58 encoded) of the bot's wallet.
# This wallet will execute swaps and send airdrops.
# ⚠️ KEEP THIS SECRET — never share or commit this value!
WALLET_PRIVATE_KEY=

# The public address of the wallet receiving Pump.fun creator fees.
# The bot monitors this address for incoming SOL.
FEE_WALLET_ADDRESS=

# --- Token Configuration ---
# The $ANSEM token mint address (Contract Address).
TOKEN_MINT_ADDRESS=EPD8jj7bVhNh3o7Wx1XZ39aaacSki8p2ABaN61yhUnBh

# --- Bot Parameters ---
# Minimum SOL (in lamports) that must accumulate before triggering a buy-back.
# Default: 50000000 (0.05 SOL)
MIN_SOL_THRESHOLD=50000000

# SOL (in lamports) reserved in the fee wallet for transaction fees.
# Default: 10000000 (0.01 SOL)
RESERVED_SOL_FOR_FEES=10000000

# Polling interval in milliseconds (fallback if WebSocket drops).
# Default: 30000 (30 seconds)
POLLING_INTERVAL_MS=30000

# --- Swap Configuration ---
# Maximum slippage in basis points (1 bps = 0.01%).
# Default: 50 (0.5%)
SLIPPAGE_BPS=50

# Maximum acceptable price impact percentage.
# Swaps exceeding this will be rejected.
# Default: 5
MAX_PRICE_IMPACT_PERCENT=5

# --- Jito MEV Protection ---
# Jito tip amount in lamports. Higher tips = higher bundle landing probability.
# Default: 5000000 (0.005 SOL)
JITO_TIP_LAMPORTS=5000000

# --- Airdrop Configuration ---
# Minimum token balance (in raw units) a holder must have to qualify for airdrop.
# Default: 1000000 (assuming 6 decimals = 1 token)
AIRDROP_DUST_THRESHOLD=1000000

# Number of recipients per airdrop transaction batch.
# Default: 20
AIRDROP_BATCH_SIZE=20

# --- Operational Mode ---
# Set to 'true' to run in dry-run mode (no actual transactions sent).
# Useful for testing and verification.
DRY_RUN=false
